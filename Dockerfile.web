# ─── Dockerfile.web ───────────────────────────────────────────────────────────
# CloudIDE Frontend — Production build (React + Vite → static files + nginx)
# ──────────────────────────────────────────────────────────────────────────────

# ─── Stage 1: Builder ────────────────────────────────────────────────────────
FROM node:20-slim AS builder

WORKDIR /app
RUN npm install -g pnpm@10

# Copy workspace manifests
COPY package.json pnpm-workspace.yaml ./
COPY artifacts/cloud-ide/package.json ./artifacts/cloud-ide/
COPY lib/db/package.json               ./lib/db/
COPY lib/api-spec/package.json         ./lib/api-spec/
COPY lib/api-zod/package.json          ./lib/api-zod/
COPY lib/api-client-react/package.json ./lib/api-client-react/
COPY scripts/package.json              ./scripts/

RUN pnpm install --frozen-lockfile

COPY tsconfig.base.json tsconfig.json ./
COPY lib/ ./lib/
COPY artifacts/cloud-ide/ ./artifacts/cloud-ide/

# Build the frontend
RUN pnpm --filter @workspace/cloud-ide run build

# ─── Stage 2: nginx static server ────────────────────────────────────────────
FROM nginx:alpine AS production

# Copy built frontend
COPY --from=builder /app/artifacts/cloud-ide/dist /usr/share/nginx/html

# nginx config for SPA (all routes → index.html)
RUN cat > /etc/nginx/conf.d/default.conf << 'EOF'
server {
    listen 3000;
    root /usr/share/nginx/html;
    index index.html;

    # Serve static assets with caching
    location ~* \.(js|css|png|jpg|ico|svg|woff2?)$ {
        expires 1y;
        add_header Cache-Control "public, immutable";
    }

    # SPA routing: all unmatched routes → index.html
    location / {
        try_files $uri $uri/ /index.html;
    }
}
EOF

EXPOSE 3000
CMD ["nginx", "-g", "daemon off;"]
