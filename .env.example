# ─── CloudIDE Environment Variables ───────────────────────────────────────────
# Copy this file to .env and fill in real values before running.
#
# Generate secure secrets:
#   openssl rand -hex 32   → for JWT_SECRET, SESSION_SECRET
#   openssl rand -hex 16   → for POSTGRES_PASSWORD
# ──────────────────────────────────────────────────────────────────────────────

# ── REQUIRED ──────────────────────────────────────────────────────────────────

# PostgreSQL password (used in docker-compose DATABASE_URL)
POSTGRES_PASSWORD=change_me_strong_password

# JWT signing secret — min 32 chars, keep secret
JWT_SECRET=change_me_generate_with_openssl_rand_hex_32

# Session secret (can be same as JWT_SECRET)
SESSION_SECRET=change_me_generate_with_openssl_rand_hex_32

# Your CloudIDE frontend URL (used for OAuth redirects)
FRONTEND_URL=http://localhost

# ── OPTIONAL: Authentication ───────────────────────────────────────────────────

# GitHub OAuth (for "Sign in with GitHub" button)
# Create at: https://github.com/settings/developers
# Callback URL: http://your-domain.com/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (for "Sign in with Google" button)
# Create at: https://console.developers.google.com
GOOGLE_CLIENT_ID=

# ── OPTIONAL: AI Code Assistant ───────────────────────────────────────────────

# OpenAI API key — enables the AI code assistant
OPENAI_API_KEY=

# ── OPTIONAL: Admin ───────────────────────────────────────────────────────────

# Admin token for Bull Board dashboard at /api/admin/queues
ADMIN_TOKEN=

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
